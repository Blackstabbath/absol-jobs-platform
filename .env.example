SECRET_KEY=change-me
DEBUG=0
ALLOWED_HOSTS=yourusername.pythonanywhere.com
TIME_ZONE=America/Toronto

# PythonAnywhere MySQL example:
# DATABASE_URL=mysql://username:password@username.mysql.pythonanywhere-services.com/username$absol_jobs
DATABASE_URL=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=applications@example.com
EMAIL_HOST_PASSWORD=app-password
DEFAULT_FROM_EMAIL=applications@example.com

MAX_UPLOAD_SIZE_MB=15
